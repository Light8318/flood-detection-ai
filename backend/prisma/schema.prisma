generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Location {
  id          Int      @id @default(autoincrement())
  name        String
  latitude    Float
  longitude   Float
  state       String?
  country     String?
  updatedAt   DateTime? @updatedAt

  weatherData WeatherData[]
  predictions FloodPrediction[]
}

model WeatherData {
  id          Int      @id @default(autoincrement())

  temperature Float
  humidity    Int
  rainfall    Float
  windSpeed   Float
  pressure    Float?

  timestamp   DateTime
  createdAt   DateTime @default(now())

  locationId  Int
  location    Location @relation(fields: [locationId], references: [id])
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      String   @default("user")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  reports      Report[]
  predictions  FloodPrediction[]
  adminActions AdminAction[]
}

model Report {
  id          Int      @id @default(autoincrement())
  description String   @db.Text
  imageUrl    String?
  address     String
  latitude    Float?
  longitude   Float?
  status         String    @default("PENDING")
  severity       String    @default("UNKNOWN")
  adminResponse  String?   @db.Text
  respondedBy    String?
  respondedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  userId Int
  user   User @relation(fields: [userId], references: [id])

  predictions FloodPrediction[]
}

model FloodPrediction {
  id              Int      @id @default(autoincrement())

  // Rule-based risk fields
  riskLevel       String
  riskScore       Int
  reasons         Json

  // Gemini weather-analysis output
  aiAnalysis      String?  @db.Text
  recommendation  String?  @db.Text

  // Gemini image-analysis output (populated only when an image is provided)
  imageAnalysis   String?  @db.Text
  floodSeverity   String?
  confidence      Float?
  rescuePriority  String?

  // Weather snapshot stored at prediction time
  temperature     Float
  humidity        Int
  rainfall        Float
  windSpeed       Float
  pressure        Float?

  locationName    String
  latitude        Float
  longitude       Float

  createdAt       DateTime @default(now())

  userId     Int
  user       User      @relation(fields: [userId], references: [id])

  locationId Int?
  location   Location? @relation(fields: [locationId], references: [id])

  // Optional link to a user-submitted flood report that triggered this prediction
  reportId   Int?
  report     Report?   @relation(fields: [reportId], references: [id])
}

model AdminAction {
  id         Int      @id @default(autoincrement())
  action     String
  targetType String
  targetId   Int
  notes      String?  @db.Text
  createdAt  DateTime @default(now())

  adminId Int
  admin   User @relation(fields: [adminId], references: [id])
}
